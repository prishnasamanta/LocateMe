# ─── Firebase (required for two different phones) ───
# Get these from: Firebase Console → Project Settings → Your apps → Web app → firebaseConfig
# Or paste the whole config at http://localhost:5173/setup (saved in browser for local dev)
#
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef123456

# Production URL (Render): https://your-app.onrender.com
VITE_APP_URL=

# ─── After filling values ───
# 1. Copy this file to .env for local dev
# 2. Enable Firestore + Google Auth in Firebase Console
# 3. Deploy rules: npx firebase deploy --only firestore:rules
# 4. On Render: add the same VITE_* vars in Environment, then redeploy
